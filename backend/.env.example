# Copy this file to .env and fill in real values. Never commit .env.
# All keys listed here are required for full functionality unless marked optional.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at supabase.com, then copy from Settings → API.
# SERVICE_KEY bypasses Row Level Security — treat as a root password.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── SnapTrade ─────────────────────────────────────────────────────────────────
# Register at snaptrade.com/developers to get these
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ── Market data ───────────────────────────────────────────────────────────────
ALPHAVANTAGE_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Optional — from-address and autobot recipient. Defaults exist in code.
RESEND_FROM=
AUTOBOT_EMAIL_TO=

# ── Stripe (optional — pro tier billing) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Runtime (optional — sensible defaults exist) ──────────────────────────────
# DATA_DIR overrides where JSON state files live (defaults to backend/).
DATA_DIR=
# HARVEST_DEV=1 disables static file serving so Vite owns port 5173 in dev.
HARVEST_DEV=
