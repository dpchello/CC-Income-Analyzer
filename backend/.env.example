# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-before-production

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at supabase.com, then copy from Settings → API
SUPABASE_URL=REDACTED-SUPABASE-URL
SUPABASE_SERVICE_KEY=REDACTED-SUPABASE-SERVICE-KEY


# ── SnapTrade ─────────────────────────────────────────────────────────────────
# Register at snaptrade.com/developers to get these
SNAPTRADE_CLIENT_ID=REDACTED-SNAPTRADE-CLIENT-ID
SNAPTRADE_CONSUMER_KEY=REDACTED-SNAPTRADE-CONSUMER-KEY

# ── Market data ───────────────────────────────────────────────────────────────
ALPHAVANTAGE_API_KEY=REDACTED-ALPHAVANTAGE-KEY

# ── Stripe (optional — pro tier billing) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
