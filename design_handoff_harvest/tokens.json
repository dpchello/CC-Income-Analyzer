{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Harvest",
  "description": "Design tokens for Harvest, a covered-call platform for long-term holders. Paper-white surface with deep forest green accent.",
  "color": {
    "bg": { "value": "#faf8f3", "comment": "Page background — warm off-white" },
    "bg-elev": { "value": "#f3f0e7", "comment": "Subtle elevation (sidebars, section bands)" },
    "bg-elev-2": { "value": "#ebe7db" },
    "bg-card": { "value": "#ffffff", "comment": "Cards, tables, ticket surface" },

    "fg": { "value": "#1a1e16", "comment": "Primary text — warm near-black" },
    "fg-dim": { "value": "#4a4f44" },
    "fg-mute": { "value": "#6e7166" },
    "fg-faint": { "value": "#9a9a90" },

    "line": { "value": "rgba(24,28,20,0.10)" },
    "line-strong": { "value": "rgba(24,28,20,0.18)" },
    "line-soft": { "value": "rgba(24,28,20,0.06)" },

    "accent": { "value": "#2f5233", "comment": "Brand accent — deep forest. Primary buttons, positive P&L, active nav, chart lines. Also referenced as --acid in the prototype for historical reasons." },
    "accent-dim": { "value": "#3f6844" },
    "accent-deep": { "value": "#1e3621", "comment": "Primary button hover" },
    "accent-faint": { "value": "rgba(47,82,51,0.08)", "comment": "Selected strike, selected preset chip" },
    "accent-line": { "value": "rgba(47,82,51,0.28)" },

    "warn": { "value": "#b8502e", "comment": "Assignment risk, earnings windows" },
    "warn-faint": { "value": "rgba(184,80,46,0.10)" },
    "down": { "value": "#c14a35", "comment": "Losses, negative day change" },

    "olive": { "value": "#6a7648", "comment": "Secondary accent — medium conviction" },
    "olive-dim": { "value": "#4a5436" }
  },

  "font": {
    "sans": { "value": "'Inter Tight', 'Inter', -apple-system, sans-serif", "comment": "Primary UI, buttons, nav" },
    "body": { "value": "'Inter', -apple-system, sans-serif", "comment": "Body paragraphs" },
    "serif": { "value": "'Instrument Serif', 'Cormorant Garamond', Georgia, serif", "comment": "Editorial display — hero titles, screen titles" },
    "mono": { "value": "'JetBrains Mono', 'IBM Plex Mono', ui-monospace, monospace", "comment": "Tabular numbers, tickers, timestamps, eyebrows" }
  },

  "size": {
    "display": { "value": "60px", "comment": "Hero equity display" },
    "title-xl": { "value": "48px" },
    "title-lg": { "value": "30px" },
    "title": { "value": "22px" },
    "body-lg": { "value": "16px" },
    "body": { "value": "14px" },
    "label": { "value": "13px" },
    "meta": { "value": "12px" },
    "eyebrow": { "value": "11px" },
    "micro": { "value": "10px" }
  },

  "radius": {
    "1": { "value": "2px", "comment": "Default — cards, chips, tiles" },
    "2": { "value": "4px" },
    "3": { "value": "8px" },
    "4": { "value": "12px" }
  },

  "spacing": {
    "comment": "Loose 4px grid — common paddings",
    "values": [12, 16, 18, 20, 24, 28, 32, 40, 48, 56, 72, 96, 120]
  },

  "shadow": {
    "card-hover": { "value": "0 4px 12px rgba(24,28,20,0.06)" },
    "modal": { "value": "0 30px 80px rgba(24,28,20,0.12), 0 0 0 1px rgba(47,82,51,0.08)" }
  },

  "motion": {
    "ui": { "value": "150ms ease", "comment": "Background/border color changes, hover states" },
    "modal": { "value": "200ms cubic-bezier(0.2, 0.8, 0.2, 1)" }
  }
}
